# Copy to .env (or set in your MCP client config) and fill in your key.
# Get a free Steam Web API key at: https://steamcommunity.com/dev/apikey
STEAM_API_KEY=

# Optional: your own Steam name (vanity name, SteamID64, or profile URL). When
# set, the "about me" tools default to you when you don't name a user. Not a
# secret — it's a public profile name.
STEAM_USER=